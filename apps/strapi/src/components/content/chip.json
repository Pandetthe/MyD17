{
  "collectionName": "components_content_chips",
  "info": {
    "displayName": "Chip",
    "icon": "bulletList"
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string",
      "minLength": 1,
      "required": true
    },
    "icon": {
      "type": "customField",
      "customField": "plugin::strapi-lucide-icons.icon",
      "required": true
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "required": true
    },
    "variant": {
      "type": "enumeration",
      "enum": ["normal", "phone", "email", "link", "copy"],
      "required": true,
      "default": "normal"
    }
  },
  "config": {}
}
