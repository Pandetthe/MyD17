{
  "kind": "collectionType",
  "collectionName": "tags",
  "info": {
    "singularName": "tag",
    "pluralName": "tags",
    "displayName": "Tag"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "minLength": 1,
      "required": true,
      "unique": true
    },
    "color": {
      "type": "customField",
      "customField": "plugin::color-picker.color",
      "required": true
    },
    "posts": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::post.post",
      "inversedBy": "tags"
    },
    "push_subscribers": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::push-subscriber.push-subscriber",
      "mappedBy": "tags"
    }
  }
}
