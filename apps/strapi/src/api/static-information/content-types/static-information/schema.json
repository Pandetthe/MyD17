{
  "kind": "collectionType",
  "collectionName": "static_informations",
  "info": {
    "singularName": "static-information",
    "pluralName": "static-informations",
    "displayName": "Info Card"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "isWide": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "color": {
      "type": "customField",
      "customField": "plugin::color-picker.color",
      "required": true
    },
    "icon": {
      "type": "customField",
      "customField": "plugin::strapi-lucide-icons.icon",
      "required": true
    },
    "content": {
      "type": "dynamiczone",
      "components": [
        "content.text",
        "content.location",
        "content.event-date-time",
        "content.chip",
        "content.calendar"
      ]
    }
  }
}
