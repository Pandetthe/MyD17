{
  "kind": "collectionType",
  "collectionName": "posts",
  "info": {
    "singularName": "post",
    "pluralName": "posts",
    "displayName": "Post"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "minLength": 1,
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "mappedBy": "posts"
    },
    "likesCount": {
      "type": "integer",
      "required": true,
      "default": 0,
      "min": 0
    },
    "content": {
      "type": "dynamiczone",
      "components": [
        "content.calendar",
        "content.location",
        "content.text",
        "content.event-date-time",
        "content.chip",
        "content.section-title"
      ],
      "required": true
    }
  }
}
