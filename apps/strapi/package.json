{
  "name": "strapi",
  "version": "1.0.11",
  "private": true,
  "description": "A Strapi application",
  "scripts": {
    "build": "strapi build",
    "console": "strapi console",
    "deploy": "strapi deploy",
    "dev": "strapi develop",
    "develop": "strapi develop",
    "start": "strapi start",
    "strapi": "strapi",
    "upgrade": "npx @strapi/upgrade latest",
    "upgrade:dry": "npx @strapi/upgrade latest --dry",
    "test": "jest --forceExit --detectOpenHandles",
    "check-types": "tsc --noEmit && tsc --noEmit -p src/admin/tsconfig.json",
    "types:check": "pnpm check-types",
    "lint": "pnpm lint:fix && pnpm lint:check",
    "lint:check": "prettier --check \"src/plugins/**/*.{ts,tsx,js}\"",
    "lint:fix": "prettier --write \"src/plugins/**/*.{ts,tsx,js}\"",
    "format": "prettier --write \"src/plugins/**/*.{ts,tsx,js}\""
  },
  "dependencies": {
    "@strapi/plugin-cloud": "5.46.0",
    "@strapi/plugin-documentation": "5.46.0",
    "@strapi/plugin-users-permissions": "5.45.0",
    "@strapi/strapi": "5.46.0",
    "@strapi/admin": "5.46.0",
    "@strapi/design-system": "2.2.0",
    "@strapi/icons": "2.2.0",
    "lucide-react": "^1.0.0",
    "react-intl": "6.6.2",
    "pg": "8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "styled-components": "^6.4.1"
  },
  "devDependencies": {
    "@types/koa": "2.15.1",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^18.3.7",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0 <=24.x.x",
    "npm": ">=6.0.0"
  },
  "strapi": {
    "uuid": "b53ed786-fd57-4fff-8c32-c556a1d69384",
    "installId": "b69eddbde5e32d0edc9647405ff05749fc1134227be51b43c434f7bcf630e4bc"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      ".tmp",
      ".cache"
    ],
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^/create-service$": "<rootDir>/create-service"
    }
  }
}
