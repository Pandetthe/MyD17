{
  "name": "strapi",
  "version": "1.0.0",
  "private": true,
  "description": "A Strapi application",
  "scripts": {
    "build": "strapi build",
    "console": "strapi console",
    "deploy": "strapi deploy",
    "dev": "strapi develop",
    "develop": "strapi develop",
    "start": "strapi start",
    "strapi": "strapi",
    "upgrade": "npx @strapi/upgrade latest",
    "upgrade:dry": "npx @strapi/upgrade latest --dry",
    "test": "jest --forceExit --detectOpenHandles",
    "check-types": "tsc --noEmit && tsc --noEmit -p src/admin/tsconfig.json",
    "types:check": "pnpm check-types",
    "lint": "pnpm lint:fix && pnpm lint:check",
    "lint:check": "prettier --check \"src/plugins/**/*.{ts,tsx,js}\"",
    "lint:fix": "prettier --write \"src/plugins/**/*.{ts,tsx,js}\"",
    "format": "prettier --write \"src/plugins/**/*.{ts,tsx,js}\""
  },
  "dependencies": {
    "@strapi/admin": "5.49.0",
    "@strapi/design-system": "2.2.1",
    "@strapi/icons": "2.2.1",
    "@strapi/plugin-cloud": "5.49.0",
    "@strapi/plugin-documentation": "5.49.0",
    "@strapi/plugin-users-permissions": "5.49.0",
    "@strapi/strapi": "5.49.0",
    "firebase-admin": "^14.1.0",
    "lucide-react": "^1.21.0",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-intl": "10.1.14",
    "react-router-dom": "^6.30.4",
    "styled-components": "^6.4.3"
  },
  "devDependencies": {
    "@types/koa": "3.0.3",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0 <=24.x.x",
    "npm": ">=6.0.0"
  },
  "strapi": {
    "uuid": "b53ed786-fd57-4fff-8c32-c556a1d69384",
    "installId": "b69eddbde5e32d0edc9647405ff05749fc1134227be51b43c434f7bcf630e4bc"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      ".tmp",
      ".cache"
    ],
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^/create-service$": "<rootDir>/create-service"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "./tsconfig.jest.json"
        }
      ]
    },
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).[jt]s"
    ]
  }
}
