    "types:check": "tsc --noEmit",
    "test": "jest -i --forceExit --passWithNoTests",
    "test:e2e:ios": "bash scripts/e2e-ios.sh",
    "test:e2e:ios:run": "bash scripts/e2e-ios-run.sh",
